# Copie este arquivo para .env e ajuste conforme necessário.
# .env NÃO deve ser commitado (já está no .gitignore).

# Banco de dados PostgreSQL
POSTGRES_DB=taskmanager
POSTGRES_USER=taskmanager
POSTGRES_PASSWORD=taskmanager

# App → Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=taskmanager
DB_USER=taskmanager
DB_PASSWORD=taskmanager

# Spring
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
DDL_AUTO=update

# JWT — IMPORTANTE: trocar em produção por chave forte (mínimo 256 bits).
